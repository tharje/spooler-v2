# Spooler environment variables
# Copy this file to .env and fill in the values.

# ── Authentication ─────────────────────────────────────────────────────────────

# Set to false to disable authentication entirely (for trusted LAN use only).
# AUTH_ENABLED=true

# Username for the login form (default: admin).
# SPOOLER_USERNAME=admin

# bcrypt hash of your password. Overrides any password set via the web UI.
# Generate one with:  python3 server.py --hash-password
# SPOOLER_PW_HASH=$2b$12$changeme

# ── Ports ──────────────────────────────────────────────────────────────────────

# HTTP_PORT=8080
# HTTPS_PORT=8443
# WS_PORT=8765

# ── TLS / HTTPS ────────────────────────────────────────────────────────────────

# Set to false when running behind a reverse proxy (Traefik, nginx, Caddy, etc.)
# that handles TLS termination. Disables the built-in self-signed cert and HTTPS server.
# HTTPS_ENABLED=true

# Set to true when behind a TLS-terminating reverse proxy so the session cookie
# carries the Secure flag (even though the app itself is serving HTTP internally).
# SECURE_COOKIES=false

# ── Spoolman ───────────────────────────────────────────────────────────────────

# Spoolman API base URL. Overrides the URL set in the web UI when specified here.
# SPOOLMAN_URL=http://localhost:7912

# ── Debug ──────────────────────────────────────────────────────────────────────

# Set to 1 to enable verbose MQTT/protocol logging (full payloads, unknown keys).
# DEBUG=0
